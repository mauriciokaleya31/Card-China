    "@types/react-signature-canvas": "^1.0.7",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
